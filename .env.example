# CA Intelligence Environment Configuration

# Application Environment
ENV=development
PORT=8000

# Database Settings
# For local Python runs, default to SQLite or local PostgreSQL.
# For Docker Compose, the URL will point to the database service container.
DATABASE_URL=sqlite:///./caintelligence.db
# DATABASE_URL=postgresql://postgres:postgres@db:5432/caintelligence

# Security and Authentication
JWT_SECRET=supersecretjwtkeyforlocaldevelopmentonly123!
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI Provider Configurations (gemini, openai, anthropic, mock)
LLM_PROVIDER=mock
EMBEDDING_PROVIDER=mock
OCR_PROVIDER=mock

OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Storage settings (local, s3)
STORAGE_PROVIDER=local
LOCAL_STORAGE_DIR=./uploads
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=
